# Database
# Local Docker default — Vercel deploys should point at Neon (or any hosted
# Postgres) using a pooled connection string with `?sslmode=require`.
#
# On Vercel, the Storage / Marketplace integrations (Neon, Supabase, Postgres)
# auto-set `STORAGE_DATABASE_URL` (default `STORAGE` prefix) — the code falls
# back to it (and `POSTGRES_URL`) automatically, so you don't have to rename
# anything in the Vercel UI.
#
# Example: postgres://user:pass@ep-xxxx-pooler.region.aws.neon.tech/db?sslmode=require
DATABASE_URL=postgres://workfully:workfully@localhost:5432/workfully

# OpenRouter API key (proxies Claude, GPT, Gemini, etc.)
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Optional: model override (defaults to anthropic/claude-sonnet-4.6)
# OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
